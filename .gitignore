.DS_Store
.env
.env.*
!.env.example

# Local component repositories are installed by knot-setup.
components/

# Recoverable agent planning state.
.state/

# User, customer, and generated work data.
workspace/

# IM gateway configs, secrets, logs, sockets, locks, and local runtime files.
# Runtime files are generated locally by knot-setup. Keep reusable templates in
# .skills/knot-setup/references/ instead of committing live runtime config.
runtime/

# Common generated/cache output.
**/.cache/
**/node_modules/
**/__pycache__/
**/.pytest_cache/
