# Knot scaffold environment

# Set this to the install root when a runtime needs an explicit workspace path.
KNOT_ROOT=

# Optional external Obsidian vault path. If unset, use workspace/knowledge/vault.
OBSIDIAN_VAULT_PATH=

# Optional Git-backed approved knowledge vault. The approved ref is the only
# durable runtime source; local proposal bundles are review inputs.
KNOT_KNOWLEDGE_REPO_URL=
KNOT_KNOWLEDGE_LOCAL_MIRROR=
KNOT_KNOWLEDGE_APPROVED_REF=main
